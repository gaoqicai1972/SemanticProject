<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fanuc Focas 智能助手" Height="750" Width="1000" 
        Background="#F4F7F9" FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0067C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#AABBC9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UserBubble" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#005A9E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="15,15,2,15"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="60,5,10,5"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AssistantBubble" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E6ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="15,15,15,2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="10,5,60,5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" Padding="20,15" BorderBrush="#E0E6ED" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border Width="10" Height="10" Background="#2ECC71" CornerRadius="5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Fanuc Focas 专家" FontSize="16" FontWeight="SemiBold" Foreground="#2C3E50"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" Padding="10">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Border x:Name="MsgBubble">
                                <ContentControl x:Name="Renderer" Content="{Binding}"/>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Role}" Value="User">
                                <Setter TargetName="MsgBubble" Property="Style" Value="{StaticResource UserBubble}"/>
                                <Setter TargetName="Renderer" Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Content}" Foreground="White" FontSize="14" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                <Setter TargetName="MsgBubble" Property="Style" Value="{StaticResource AssistantBubble}"/>
                                <Setter TargetName="Renderer" Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <RichTextBox IsReadOnly="True" BorderThickness="0" Background="Transparent" 
                                                         Tag="{Binding Content}" Loaded="RichTextBox_Loaded"/>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E6ED" BorderThickness="0,1,0,0" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <Border Background="#F0F4F8" CornerRadius="10" Padding="10,5">
                    <TextBox x:Name="InputBox" Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" 
                             BorderThickness="0" Background="Transparent"
                             FontSize="14" MinHeight="40" MaxHeight="120"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SendMessageCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>

                <Button Grid.Column="1" Content="发送" Margin="15,0,0,0"
                        Command="{Binding SendMessageCommand}"
                        Style="{StaticResource ModernButtonStyle}"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <ProgressBar Grid.Row="1" VerticalAlignment="Top" Height="2" 
                     IsIndeterminate="True" BorderThickness="0" Background="Transparent" Foreground="#0078D4"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
    </Grid>
</Window>